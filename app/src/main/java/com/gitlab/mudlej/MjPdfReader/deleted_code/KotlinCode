package com.gitlab.mudlej.MjPdfReader.data

import android.os.Parcel
import android.os.Parcelable
import com.shockwave.pdfium.PdfDocument

class Bookmark(bookmark:PdfDocument.Bookmark, val level: Int) : PdfDocument.Bookmark(), Parcelable {
    val subBookmarks: MutableList<Bookmark> = mutableListOf()

    init {
        title = bookmark.title
        pageIdx = bookmark.pageIdx
        mNativePtr = bookmark.mNativePtr
        if (hasChildren())
            for (child in children)
                subBookmarks.add(Bookmark(child, level + 1))
    }

    constructor(parcel: Parcel) : this(createFromParcel(parcel), parcel.readInt()) {
        title = parcel.readString()
        pageIdx = parcel.readLong()
        mNativePtr = parcel.readLong()
        parcel.readList(subBookmarks, Bookmark::class.java.classLoader)
    }

    override fun describeContents(): Int {
    }

    override fun writeToParcel(destination: Parcel, p1: Int) {
        destination.writeString(title)
        destination.writeInt(level)
        destination.writeLong(pageIdx)
        destination.writeLong(mNativePtr)
        destination.writeList(subBookmarks)
    }

    companion object CREATOR : Parcelable.Creator<Bookmark> {
        override fun createFromParcel(parcel: Parcel): Bookmark {
            return Bookmark(parcel)
        }

        override fun newArray(size: Int): Array<Bookmark?> {
            return arrayOfNulls(size)
        }
    }

}

