<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
<!--        <item name="android:windowTranslucentStatus">true</item>-->
<!--        <item name="android:windowTranslucentNavigation">true</item>-->
    </style>

<!--    <style name="MJ_PDF_THEME" parent="Theme.AppCompat.DayNight.DarkActionBar" >-->
    <style name="MJ_PDF_THEME" parent="Theme.Material3.Dark" >
        <item name="android:actionOverflowButtonStyle">@style/MJ_PDF_THEME.OverFlow</item>
        <item name="actionOverflowMenuStyle">@style/CMOptionsMenu</item>
        <item name="android:itemTextAppearance">@style/TextAppearance</item>
    </style>

    <!-- to change (color and margin) of the more icon option in the appBar   -->
    <style name="MJ_PDF_THEME.OverFlow">
        <item name="android:src">@drawable/ic_more_vert</item>
        <item name="android:padding" tools:targetApi="o">12dp</item>
    </style>

    <!-- To change the background of options menu-->
    <style name="CMOptionsMenu" parent="Widget.AppCompat.PopupMenu.Overflow">
        <item name="android:popupBackground">@color/topBarBackgroundColor</item>
    </style>

    <!-- To change text color of items in options menu-->
    <style name="TextAppearance">
        <item name="android:textColor">@color/topBarColor</item>
    </style>

    <style name="MJDialogThemeDark" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="android:background">@color/darkBackground</item>
        <item name="android:textColor">@color/onDarkBackground</item>
        <item name="textColorAlertDialogListItem">@color/onDarkBackground</item>
        <item name="colorAccent">@color/redAccent</item>        // checked choice button circle color
        <item name="colorControlNormal">@color/redAccent</item> // unchecked choice button circle color
        <item name="android:textColorPrimary">@color/onDarkBackground</item>    // Dialog message text color


        <!--        <item name="buttonBarPositiveButtonStyle">@color/topBarColor</item>-->
<!--        <item name="buttonBarNegativeButtonStyle">@color/topBarColor</item>-->
    </style>

    <style name="MJDialogThemeLight" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="android:textColor">@color/topBarBackgroundColor</item>
        <item name="android:positiveButtonText">@color/topBarBackgroundColor</item>
        <item name="android:negativeButtonText">@color/topBarBackgroundColor</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.roundedImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">5%</item>
    </style>

    <color name="redAccent">#E91E63</color>
</resources>